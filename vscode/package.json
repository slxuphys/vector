{
  "name": "vector",
  "displayName": "Vector Preview",
  "description": "Fast paginated preview and PDF export for Vector Markdown/LaTeX documents.",
  "version": "0.1.0",
  "private": true,
  "publisher": "vector",
  "type": "commonjs",
  "files": [
    "dist/extension.js",
    "webview-dist/**",
    "README.md"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "activationEvents": [
    "onCommand:vector.openPreview",
    "onCommand:vector.exportPdf",
    "onCommand:vector.revealCursorInPreview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Vector",
      "properties": {
        "vector.debug.pdf": {
          "type": "boolean",
          "default": false,
          "description": "Log PDF display-list signatures and export timings."
        }
      }
    },
    "commands": [
      {
        "command": "vector.openPreview",
        "title": "Vector: Open Preview"
      },
      {
        "command": "vector.exportPdf",
        "title": "Vector: Export PDF"
      },
      {
        "command": "vector.revealCursorInPreview",
        "title": "Vector: Reveal Cursor in Preview"
      }
    ],
    "keybindings": [
      {
        "command": "vector.revealCursorInPreview",
        "key": "ctrl+alt+enter",
        "mac": "ctrl+alt+enter",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "npm run build:webview && node esbuild.cjs",
    "build:webview": "vite build --config vite.webview.config.mts",
    "check:webview": "tsc -p tsconfig.webview.json"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
