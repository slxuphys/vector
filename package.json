    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@lezer/highlight": "^1.2.3",
    "@pdf-lib/fontkit": "^1.1.1",
    "@resvg/resvg-wasm": "^2.6.2",
    "@slxu/graphsx": "^0.1.12",
    "codemirror-lang-latex": "^0.4.1",
    "harfbuzzjs": "^1.4.0",
    "katex": "^0.16.22",
    "lucide-react": "^1.24.0",
    "mathjax-full": "^3.2.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "subset-font": "^2.5.0"
  },
  "devDependencies": {
