{
  "name": "vector-text-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "vscode"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
